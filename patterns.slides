<!-- slides/patterns/10-waitgroup.go -->
<article class='title-slide'>
  <div class='title-text'>Implementing WaitGroup</div>
  <span class='pagenumber'>3</span>
</article>
<article>
  <h1>WaitGroup unsynchronized</h1>
  <div class="flex"><div>
  <div class='code'><pre>
<span class='codenum'>1</span>type <defn>WaitGroup</defn> struct {
<span class='codenum'>2</span>   count int <comment>// number of active goroutines</comment>
<span class='codenum'>3</span>}

<span class='codenum'>4</span>func (g *WaitGroup) <defn>Go</defn>(f func()) {
<span class='codenum'>5</span>   g.Add(1)
<span class='codenum'>6</span>   go func() {
<span class='codenum'>7</span>      defer g.Done()
<span class='codenum'>8</span>      f()
<span class='codenum'>9</span>   }()
<span class='codenum'>10</span>}

<span class='codenum'>11</span>func (g *WaitGroup) <defn>Add</defn>(n int) { g.count += n }

<span class='codenum'>12</span>func (g *WaitGroup) <defn>Done</defn>() { g.Add(-1) }

<span class='codenum'>13</span>func (g *WaitGroup) <defn>Wait</defn>() {
<span class='codenum'>14</span>   <comment>// Wait for g.count to reach 0.</comment>
<span class='codenum'>15</span>}
</pre>
  </div>
  </div><div>
  <div style="height: 5em"></div>
  <div class='text'>
<p>See <a href="https://go-review.git.corp.google.com/c/go/+/717760">this CL</a>
for a recent, subtle change to <code>WaitGroup.Go</code>.</p>
  </div>
  <div style="height: 5em"></div>
  </div></div> <!-- flex -->
  <span class='pagenumber'>4</span>
</article>
<article>
  <h1>WaitGroup with a mutex</h1>
  <div class='code'><pre>
<span class='codenum'>1</span>type <defn>WaitGroup</defn> struct {
<span class='codenum'>2</span><span class="em">   mu    sync.Mutex</span>
<span class='codenum'>3</span>   count int        <comment>// number of active goroutines</comment>
<span class='codenum'>4</span>}

<span class='codenum'>5</span>func (g *WaitGroup) <defn>Add</defn>(n int) {
<span class='codenum'>6</span><span class="em">   g.mu.Lock()
<span class='codenum'>7</span>   defer g.mu.Unlock()</span>
<span class='codenum'>8</span>   g.count += n
<span class='codenum'>9</span>}
<span class='codenum'>10</span>func (g *WaitGroup) <defn>Done</defn>() { g.Add(-1) }

<span class='codenum'>11</span>func (g *WaitGroup) <defn>Wait</defn>() {
<span class='codenum'>12</span>   <comment>// Wait for g.count to reach 0.</comment>
<span class='codenum'>13</span>}
</pre>
  </div>
  <span class='pagenumber'>5</span>
</article>
<article>
  <h1>Busy-waiting (wrong)</h1>
  <div class='text'>
<p><code>Wait</code> should block until the count is zero.</p>
  </div>
  <div class="flex"><div>
  <div class='code'><pre>
<span class='codenum'>1</span>type <defn>WaitGroup</defn> struct {
<span class='codenum'>2</span>   mu    sync.Mutex
<span class='codenum'>3</span>   count int
<span class='codenum'>4</span>}

<span class='codenum'>5</span>func (g *WaitGroup) <defn>Add</defn>(n int) {
<span class='codenum'>6</span>   g.mu.Lock()
<span class='codenum'>7</span>   defer g.mu.Unlock()
<span class='codenum'>8</span>   g.count += n
<span class='codenum'>9</span>}

<span class='codenum'>10</span>func (g *WaitGroup) <defn>Done</defn>() { g.Add(-1) }
</pre>
  </div>
  </div><div>
  <div class='code bad'><pre>
<span class='codenum'>1</span>func (g *WaitGroup) <defn>Wait</defn>() {
<span class='codenum'>2</span>   g.mu.Lock()
<span class='codenum'>3</span>   defer g.mu.Unlock()
<span class='codenum'>4</span>   for g.count &gt; 0 {
<span class='codenum'>5</span>      time.Sleep(time.Millisecond)
<span class='codenum'>6</span>   }
<span class='codenum'>7</span>}
</pre>
  </div>
  <details>
    <summary>
What's the problem here?</p>
    </summary>
    <div class='answer'>
<p><code>Wait</code> holds the mutex for its entire lifetime,
so <code>Done</code> is blocked.</p>
    </div>
  </details>
  </div></div> <!-- flex -->
  <span class='pagenumber'>6</span>
</article>
<article>
  <h1>Busy-waiting (better)</h1>
  <div class="flex"><div>
  <div class='code weak'><pre>

<span class='codenum'>1</span>func (g *WaitGroup) <defn>Wait</defn>() {
<span class='codenum'>2</span>   for {
<span class='codenum'>3</span>      g.mu.Lock()
<span class='codenum'>4</span>      c := g.count
<span class='codenum'>5</span>      g.mu.Unlock()
<span class='codenum'>6</span>      if c &lt;= 0 {
<span class='codenum'>7</span>         break
<span class='codenum'>8</span>      }
<span class='codenum'>9</span>      time.Sleep(time.Millisecond)
<span class='codenum'>10</span>   }
<span class='codenum'>11</span>}
</pre>
  </div>
  <details>
    <summary>
What's wrong with busy-waiting?</p>
    </summary>
    <div class='answer'>
<ul>
<li>Sleep too long: waste time</li>
<li>Sleep too short: waste CPU</li>
</ul>
    </div>
  </details>
  </div><div>
  <details>
    <summary>
Find the bug.</p>
    </summary>
    <div class='answer'>
<p><code>Wait</code> might not notice a 0 count.</p>
<div class="interleave" style="font-size: 70%">
<table>
<thead>
<tr>
<th>G-wait</th>
<th>G-other</th>
</tr>
</thead>
<tbody>
<tr>
<td></td>
<td>Add(1)</td>
</tr>
<tr>
<td>c := g.count</td>
<td></td>
</tr>
<tr>
<td>Sleep</td>
<td></td>
</tr>
<tr>
<td></td>
<td>Done()</td>
</tr>
<tr>
<td></td>
<td>Add(1)*</td>
</tr>
<tr>
<td>c := g.count</td>
<td></td>
</tr>
<tr>
<td>Sleep</td>
<td></td>
</tr>
</tbody>
</table>
</div>
<div style="font-size: 70%; line-height: 1.0; margin-top: 20px">
*Technically, this is disallowed:
"Note that calls with a positive delta that occur when the counter is zero must happen before a Wait."
</div>
    </div>
  </details>
  </div></div> <!-- flex -->
  <span class='pagenumber'>7</span>
</article>
<article>
  <h1>Fixing busy-waiting Wait</h1>
  <div class='text'>
<p><code>Wait</code> should actually wait.</p>
  </div>
  <details>
    <summary>
What synchronization feature will make a goroutine
wait until something happens?<br/>
And how should we use it?</p>
    </summary>
    <div class='answer'>
<p>A channel.</p>
<p>We should close it when <code>count</code> is zero, to broadcast to
all waiting goroutines.</p>
    </div>
    <div class='code'><pre>
<span class='codenum'>1</span>type <defn>WaitGroup</defn> struct {
<span class='codenum'>2</span>   mu    sync.Mutex
<span class='codenum'>3</span>   count int           <comment>// number of active goroutines</comment>
<span class='codenum'>4</span>   done  chan struct{} <comment>// closed when count == 0</comment>
<span class='codenum'>5</span>}
</pre>
    </div>
    <span class='pagenumber'>8</span>
  </article>
  <article>
    <h1>Fixing busy-waiting Wait</h1>
    <div class="flex"><div>
    <div class='code'><pre>

<span class='codenum'>1</span>func <defn>NewWaitGroup</defn>() *WaitGroup {
<span class='codenum'>2</span>   return &amp;WaitGroup{done: make(chan struct{})}
<span class='codenum'>3</span>}

<span class='codenum'>4</span>func (g *WaitGroup) <defn>Add</defn>(n int) {
<span class='codenum'>5</span>   g.mu.Lock()
<span class='codenum'>6</span>   defer g.mu.Unlock()
<span class='codenum'>7</span>   g.count += n
<span class='codenum'>8</span>   if g.count == 0 {
<span class='codenum'>9</span>      close(g.done)
<span class='codenum'>10</span>   }
<span class='codenum'>11</span>}
</pre>
    </div>
    </div><div>
    <details>
      <summary>
What should the body of Wait be?</p>
      </summary>
      <div class='code'><pre>
<span class='codenum'>1</span>func (g *WaitGroup) <defn>Wait</defn>() {
<span class='codenum'>2</span>   &lt;-g.done
<span class='codenum'>3</span>}
</pre>
      </div>
      </div></div> <!-- flex -->
      <span class='pagenumber'>9</span>
    </article>
    <article>
      <h1>Exercise</h1>
      <details>
        <summary>
Find the race condition.</p>
        </summary>
        <div class='answer'>
<p>Wait reads <code>g.done</code> without the lock.</p>
        </div>
      </details>
      <details>
        <summary>
This WaitGroup can't be used for a second wave of <code>Go</code> calls: once the first
group of goroutines completes, the channel is nil, and <code>Wait</code> will never return.</p>
<p>How can we fix that?</p>
        </summary>
        <div class='answer'>
<p>TODO</p>
        </div>
      </details>
      <span class='pagenumber'>10</span>
    </article>
    <article>
      <h1>Fixing the race</h1>
      <div class='text'>
<ul>
<li>Channel <em>operations</em> are concurrency-safe</li>
<li>But <em>accessing a variable</em> (even one holding a channel) is not</li>
</ul>
      </div>
      <div class='code'><pre>
<span class='codenum'>1</span>type <defn>WaitGroup</defn> struct {
<span class='codenum'>2</span>   mu    sync.Mutex
<span class='codenum'>3</span>   count int           <comment>// number of active goroutines</comment>
<span class='codenum'>4</span>   done  chan struct{} <comment>// closed when count reaches zero</comment>
<span class='codenum'>5</span>}

<span class='codenum'>6</span>func (g *WaitGroup) <defn>Go</defn>(f func()) {
<span class='codenum'>7</span>   g.add(1)
<span class='codenum'>8</span>   go func() {
<span class='codenum'>9</span>      defer g.add(-1)
<span class='codenum'>10</span>      f()
<span class='codenum'>11</span>   }()
<span class='codenum'>12</span>}
</pre>
      </div>
      <div class='code'><pre>
<span class='codenum'>1</span>func (g *WaitGroup) <defn>add</defn>(n int) {
<span class='codenum'>2</span>   g.mu.Lock()
<span class='codenum'>3</span>   defer g.mu.Unlock()
<span class='codenum'>4</span>   if g.done == nil {
<span class='codenum'>5</span>      g.done = make(chan struct{})
<span class='codenum'>6</span>   }
<span class='codenum'>7</span>   g.count += n
<span class='codenum'>8</span>   if g.count == 0 {
<span class='codenum'>9</span>      close(g.done)
<span class='codenum'>10</span>      g.done = nil <comment>// Make sure we only close this channel once.</comment>
<span class='codenum'>11</span>   }
<span class='codenum'>12</span>}

<span class='codenum'>13</span><span class="em">func (g *WaitGroup) <defn>Wait</defn>() {
<span class='codenum'>14</span>   <comment>// Wait for something to be written to the channel, or for it to be closed.</comment>
<span class='codenum'>15</span>   g.mu.Lock()
<span class='codenum'>16</span>   defer g.mu.Unlock()
<span class='codenum'>17</span>   &lt;-g.done
<span class='codenum'>18</span>}
<span class='codenum'>19</span></span></pre>
      </div>
      </div></div> <!-- flex -->
      <details>
        <summary>
Find the bug.</p>
        </summary>
        <div class='answer'>
<p><code>Wait</code> holds the mutex while it's waiting, so <code>add</code> can't run to decrement the counter.</p>
        </div>
      </details>
      <span class='pagenumber'>11</span>
    </article>
    <article>
      <h1>Fix to previous</h1>
      <div class='text'>
<ul>
<li>Channel <em>operations</em> are concurrency-safe</li>
<li>But <em>accessing a variable</em> (even one holding a channel) is not</li>
</ul>
      </div>
      <div class='code'><pre>
<span class='codenum'>1</span>type <defn>WaitGroup</defn> struct {
<span class='codenum'>2</span>   mu    sync.Mutex
<span class='codenum'>3</span>   count int           <comment>// number of active goroutines</comment>
<span class='codenum'>4</span>   done  chan struct{} <comment>// closed when count reaches zero</comment>
<span class='codenum'>5</span>}

<span class='codenum'>6</span>func (g *WaitGroup) <defn>Go</defn>(f func()) {
<span class='codenum'>7</span>   g.add(1)
<span class='codenum'>8</span>   go func() {
<span class='codenum'>9</span>      defer g.add(-1)
<span class='codenum'>10</span>      f()
<span class='codenum'>11</span>   }()
<span class='codenum'>12</span>}

<span class='codenum'>13</span>func (g *WaitGroup) <defn>add</defn>(n int) {
<span class='codenum'>14</span>   g.mu.Lock()
<span class='codenum'>15</span>   defer g.mu.Unlock()
<span class='codenum'>16</span>   if g.done == nil {
<span class='codenum'>17</span>      g.done = make(chan struct{})
<span class='codenum'>18</span>   }
<span class='codenum'>19</span>   g.count += n
<span class='codenum'>20</span>   if g.count == 0 {
<span class='codenum'>21</span>      close(g.done)
<span class='codenum'>22</span>      g.done = nil <comment>// Make sure we only close this channel once.</comment>
<span class='codenum'>23</span>   }
<span class='codenum'>24</span>}

<span class='codenum'>25</span>func (g *WaitGroup) <defn>Wait</defn>() {
<span class='codenum'>26</span>   <comment>// Wait for something to be written to the channel, or for it to be closed.</comment>
<span class='codenum'>27</span><span class="em">   g.mu.Lock()
<span class='codenum'>28</span>   d := g.done
<span class='codenum'>29</span>   g.mu.Unlock()</span>
<span class='codenum'>30</span>   &lt;-d
<span class='codenum'>31</span>}
</pre>
      </div>
      <span class='pagenumber'>12</span>
    </article>
    <article>
      <h1>The real thing</h1>
      <div class='text'>
<p>Actual sync.WaitGroup implementation</p>
      </div>
      <span class='pagenumber'>13 and last</span>
    </article>

