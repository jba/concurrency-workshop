<!-- slides/mutexes-advanced/10-scope.go -->

<!-- slide 1 -->
<article class='title-slide'>
  <div class='title-text'>Advanced Mutex Topics</div>
  <span class='pagenumber'>1</span>
</article>

<!-- slide 2 -->
<article>
  <h1>Copy defensively</h1>
  <div class='text'>
<p>Copy private mutable data</p>
  </div>
  <div class='text'>
<p><code>Server.sessions</code> is managed by <code>Server</code></p>
  </div>
  <div class='text'>
<p>It doesn't want anyone else to change it.</p>
  </div>
  <div class='code'><pre>
<comment>// Sessions returns a copy of the server&#39;s sessions.</comment>
<span class='codenum'>1</span>func (s *Server) <defn>Sessions</defn>() []*ServerSession {
<span class='codenum'>2</span>   s.mu.Lock()
<span class='codenum'>3</span>   defer s.mu.Unlock()
<span class='codenum'>4</span>   return slices.Clone(s.sessions)
<span class='codenum'>5</span>}
</pre>
  </div>
  <div class='text'>
<p>From The <a href="https://github.com/modelcontextprotocol/go-sdk/blob/4cdbaaf27132e5356ba13973ae50da4edfa876bb/mcp/server.go">Go MCP SDK</a></p>
  </div>
  <span class='pagenumber'>2</span>
</article>

<!-- slide 3 -->
<article>
  <h1>Avoid locking during I/O</h1>
  <div class='text'>
<p>I/O is slow.</p>
  </div>
  <div class='text'>
<p>Network peers can be <em>arbitrarily</em> slow.</p>
  </div>
  <div class='text'>
<p>Sometimes you have to copy.</p>
  </div>
  <div class='code'><pre>
<span class='codenum'>1</span>func (s *Server) <defn>notifySessions</defn>(n string) {
<span class='codenum'>2</span>   s.mu.Lock() <comment>// required to access s.sessions</comment>
<span class='codenum'>3</span>   sessions := slices.Clone(s.sessions)
<span class='codenum'>4</span>   s.pendingNotifications[n] = nil
<span class='codenum'>5</span>   s.mu.Unlock()
<span class='codenum'>6</span>   <comment>// Do I/O with no locks held.</comment>
<span class='codenum'>7</span>   notifySessions(sessions, n, changeNotificationParams[n], s.opts.Logger)
<span class='codenum'>8</span>}
</pre>
  </div>
  <div class='text'>
<p>From The <a href="https://github.com/modelcontextprotocol/go-sdk/blob/4cdbaaf27132e5356ba13973ae50da4edfa876bb/mcp/server.go">Go MCP SDK</a></p>
  </div>
  <span class='pagenumber'>3</span>
</article>

<!-- slide 4 -->
<article>
  <h1>Avoid locking during I/O...unless you need it</h1>
  <div class='code'><pre>
<span class='codenum'>1</span>type <defn>Logger</defn> struct {
<span class='codenum'>2</span>   outMu sync.Mutex
<span class='codenum'>3</span>   out   io.Writer
<span class='codenum'>4</span>   <comment>// ...</comment>
<span class='codenum'>5</span>}

<comment>// Printf calls l.Output to print to the logger.</comment>
<span class='codenum'>6</span>func (l *Logger) <defn>Printf</defn>(format string, v ...any) {
<span class='codenum'>7</span>   l.output(0, 2, func(b []byte) []byte {
<span class='codenum'>8</span>      return fmt.Appendf(b, format, v...)
<span class='codenum'>9</span>   })
<span class='codenum'>10</span>}

<comment>// Output can take either a calldepth or a pc to get source line information.</comment>
<comment>// It uses the pc if it is non-zero.</comment>
<span class='codenum'>11</span>func (l *Logger) <defn>output</defn>(pc uintptr, calldepth int, appendOutput func([]byte) []byte) error {
<span class='codenum'>12</span>   var buf []byte
<span class='codenum'>13</span>   <comment>// ...</comment>
<span class='codenum'>14</span>   buf = appendOutput(buf)
<span class='codenum'>15</span>   <comment>// ...</comment>
<span class='codenum'>16</span><span class="em">   l.outMu.Lock()
<span class='codenum'>17</span>   defer l.outMu.Unlock()
<span class='codenum'>18</span>   _, err := l.out.Write(buf)</span>
<span class='codenum'>19</span>   return err
<span class='codenum'>20</span>}
</pre>
  </div>
  <div class='text'>
<p>From The <a href="https://github.com/golang/go/blob/e30e65f7a8bda0351d9def5a6bc91471bddafd3d/src/log/log.go">log package</a></p>
  </div>
  <span class='pagenumber'>4</span>
</article>

<!-- slides/mutexes-advanced/20-deadlock.go -->

<!-- slide 5 -->
<article>
  <h1>Our next subject</h1>
  <img height=500 src="slides/mutexes/deadlock-rebus.png"/>
  <span class='pagenumber'>5</span>
</article>

<!-- slide 6 -->
<article>
  <h1>Deadlock</h1>
  <div class='text'>
<p>Goroutines can't make progress because they block each other.</p>
  </div>
  <div class='text'>
<p>Or a single goroutine blocks itself.</p>
  </div>
  <span class='pagenumber'>6</span>
</article>

<!-- slide 7 -->
<article>
  <h1>Self-deadlock: example</h1>
  <div class="flex"><div>
  <div class='code'><pre>
<span class='codenum'>1</span>func (a *Account) <defn>Deposit</defn>(amount int) {
<span class='codenum'>2</span>   a.mu.Lock()
<span class='codenum'>3</span>   defer a.mu.Unlock()
<span class='codenum'>4</span>   a.balance += amount
<span class='codenum'>5</span>}

<span class='codenum'>6</span>func (a *Account) <defn>Withdraw</defn>(amount int) {
<span class='codenum'>7</span>   a.mu.Lock()
<span class='codenum'>8</span>   defer a.mu.Unlock()
<span class='codenum'>9</span>   a.balance -= amount
<span class='codenum'>10</span>}

<span class='codenum'>11</span>func (a *Account) <defn>TransferTo</defn>(b *Account, amount int) {
<span class='codenum'>12</span>   <comment>// Must happen atomically.</comment>
<span class='codenum'>13</span>   a.mu.Lock()
<span class='codenum'>14</span>   defer a.mu.Unlock()
<span class='codenum'>15</span>   a.Withdraw(amount)
<span class='codenum'>16</span>   b.Deposit(amount)
<span class='codenum'>17</span>}
</pre>
  </div>
  </div>
  <div> <!-- next col -->
  <div class='text'>
<div class="interleave" style="font-size: 70%">
<table>
<thead>
<tr>
<th>G</th>
</tr>
</thead>
<tbody>
<tr>
<td>astrid.TransferTo(baxter, 100)</td>
</tr>
<tr>
<td>astrid.mu.Lock()</td>
</tr>
<tr>
<td>astrid.Withdraw(100)</td>
</tr>
<tr>
<td>astrid.mu.Lock()</td>
</tr>
<tr>
<td>DEADLOCK</td>
</tr>
</tbody>
</table>
</div>
  </div>
  </div></div> <!-- flex -->
  <span class='pagenumber'>7</span>
</article>

<!-- slide 8 -->
<article>
  <h1>Solution: refactor</h1>
  <div class="flex"><div>
  <div class='code'><pre>
<span class='codenum'>1</span>func (a *Account) <defn>Deposit</defn>(amount int) {
<span class='codenum'>2</span>   a.mu.Lock()
<span class='codenum'>3</span>   defer a.mu.Unlock()
<span class='codenum'>4</span>   a.changeBalanceLocked(amount)
<span class='codenum'>5</span>}

<span class='codenum'>6</span>func (a *Account) <defn>Withdraw</defn>(amount int) {
<span class='codenum'>7</span>   a.mu.Lock()
<span class='codenum'>8</span>   defer a.mu.Unlock()
<span class='codenum'>9</span>   a.changeBalanceLocked(-amount)
<span class='codenum'>10</span>}

<comment>// The caller must hold a.mu.</comment>
<span class='codenum'>11</span>func (a *Account) <defn>changeBalanceLocked</defn>(amount int) {
<span class='codenum'>12</span>   a.balance += amount
<span class='codenum'>13</span>}
</pre>
  </div>
  </div>
  <div> <!-- next col -->
  <div class='code'><pre>
<span class='codenum'>1</span>func (a *Account) <defn>TransferTo</defn>(
<span class='codenum'>2</span>   b *Account, amount int) {
<span class='codenum'>3</span>   <comment>// Must happen atomically.</comment>
<span class='codenum'>4</span>   a.mu.Lock()
<span class='codenum'>5</span>   defer a.mu.Unlock()
<span class='codenum'>6</span>   a.changeBalanceLocked(-amount)
<span class='codenum'>7</span>   b.mu.Lock()
<span class='codenum'>8</span>   defer b.mu.Unlock()
<span class='codenum'>9</span>   b.changeBalanceLocked(amount)
<span class='codenum'>10</span>}
</pre>
  </div>
  </div></div> <!-- flex -->
  <span class='pagenumber'>8</span>
</article>

<!-- slide 9 -->
<article>
  <h1>A real-world example</h1>
  Modified from net/http/transport.go<br/>
  <div class="flex"><div>
  <div class='code small'><pre>
<span class='codenum'>1</span>type <defn>Transport</defn> struct {
<span class='codenum'>2</span>   idleMu  sync.Mutex
<span class='codenum'>3</span>   idleLRU connLRU
<span class='codenum'>4</span>   <comment>// ...</comment>
<span class='codenum'>5</span>}

<span class='codenum'>6</span>func (t *Transport) <defn>removeIdleConn1</defn>(pconn *pConn) bool {
<span class='codenum'>7</span><span class="em">   t.idleMu.Lock()</span>
<span class='codenum'>8</span>   defer t.idleMu.Unlock()
<span class='codenum'>9</span>   if pconn.idleTimer != nil {
<span class='codenum'>10</span>      pconn.idleTimer.Stop()
<span class='codenum'>11</span>   }
<span class='codenum'>12</span>   <span class="em">t.idleLRU</span>.remove(pconn)
<span class='codenum'>13</span>   <comment>// ...</comment>
<span class='codenum'>14</span>}
</pre>
  </div>
  </div>
  <div> <!-- next col -->
  <div class='code small'><pre>
<span class='codenum'>1</span>func (t *Transport) <defn>removeIdleConn</defn>(pconn *pConn) bool {
<span class='codenum'>2</span>   if pconn.isClientConn {
<span class='codenum'>3</span>      return true
<span class='codenum'>4</span>   }
<span class='codenum'>5</span>   return t.<span class="em">removeIdleConn1</span>(pconn)
<span class='codenum'>6</span>}
</pre>
  </div>
  <div class='code small'><pre>
<span class='codenum'>1</span>func (pc *pConn) <defn>closeConnIfStillIdle</defn>() {
<span class='codenum'>2</span>   t := pc.t
<span class='codenum'>3</span><span class="em">   t.idleMu.Lock()</span>
<span class='codenum'>4</span>   defer t.idleMu.Unlock()
<span class='codenum'>5</span>   if _, ok := <span class="em">t.idleLRU</span>.m[pc]; !ok {
<span class='codenum'>6</span>      return
<span class='codenum'>7</span>   }
<span class='codenum'>8</span>   t.<span class="em">removeIdleConn1</span>(pc)
<span class='codenum'>9</span>   pc.close(errIdleConnTimeout)
<span class='codenum'>10</span>}
</pre>
  </div>
  </div></div> <!-- flex -->
  <span class='pagenumber'>9</span>
</article>

<!-- slide 10 -->
<article>
  <h1>Solution: refactor</h1>
  Actually from net/http/transport.go<br/>
  <div class="flex"><div>
  <div class='code small'><pre>
<span class='codenum'>1</span>type <defn>Transport</defn> struct {
<span class='codenum'>2</span>   idleMu  sync.Mutex
<span class='codenum'>3</span>   idleLRU connLRU
<span class='codenum'>4</span>   <comment>// ...</comment>
<span class='codenum'>5</span>}

<comment>// t.idleMu must be held.</comment>
<span class='codenum'>6</span>func (t *Transport) <defn>removeIdleConnLocked</defn>(pconn *pConn) bool {
<span class='codenum'>7</span>   if pconn.idleTimer != nil {
<span class='codenum'>8</span>      pconn.idleTimer.Stop()
<span class='codenum'>9</span>   }
<span class='codenum'>10</span>   t.idleLRU.remove(pconn)
<span class='codenum'>11</span>   <comment>// ...</comment>
<span class='codenum'>12</span>}
</pre>
  </div>
  </div>
  <div> <!-- next col -->
  <div class='code small'><pre>
<span class='codenum'>1</span>func (t *Transport) <defn>removeIdleConn</defn>(pconn *pConn) bool {
<span class='codenum'>2</span>   if pconn.isClientConn {
<span class='codenum'>3</span>      return true
<span class='codenum'>4</span>   }
<span class='codenum'>5</span><span class="em">   t.idleMu.Lock()
<span class='codenum'>6</span>   defer t.idleMu.Unlock()
<span class='codenum'>7</span>   return t.removeIdleConnLocked(pconn)</span>
<span class='codenum'>8</span>}
</pre>
  </div>
  <div class='code small'><pre>
<span class='codenum'>1</span>func (pc *pConn) <defn>closeConnIfStillIdle</defn>() {
<span class='codenum'>2</span>   t := pc.t
<span class='codenum'>3</span>   t.idleMu.Lock()
<span class='codenum'>4</span>   defer t.idleMu.Unlock()
<span class='codenum'>5</span>   if _, ok := t.idleLRU.m[pc]; !ok {
<span class='codenum'>6</span>      return
<span class='codenum'>7</span>   }
<span class='codenum'>8</span><span class="em">   t.removeIdleConnLocked(pc)</span>
<span class='codenum'>9</span>   pc.close(errIdleConnTimeout)
<span class='codenum'>10</span>}
</pre>
  </div>
  </div></div> <!-- flex -->
  <span class='pagenumber'>10</span>
</article>

<!-- slide 11 -->
<article>
  <h1>Multi-goroutine deadlocks</h1>
  <div class="flex"><div>
  Reminder:<br/>
  <div class='code'><pre>
<span class='codenum'>1</span>func (a *Account) <defn>TransferTo</defn>(b *Account, amount int) {
<span class='codenum'>2</span>   <comment>// Must happen atomically.</comment>
<span class='codenum'>3</span>   a.mu.Lock()
<span class='codenum'>4</span>   defer a.mu.Unlock()
<span class='codenum'>5</span>   a.changeBalanceLocked(-amount)
<span class='codenum'>6</span>   b.mu.Lock()
<span class='codenum'>7</span>   defer b.mu.Unlock()
<span class='codenum'>8</span>   b.changeBalanceLocked(amount)
<span class='codenum'>9</span>}
</pre>
  </div>
  <br/>
  Concurrently:<br/>
  <div class='code nonum'><pre>
xena.TransferTo(yuri, 100)</pre>
  </div>
  <div class='code nonum'><pre>
yuri.TransferTo(xena, 100)</pre>
  </div>
  </div>
  <div> <!-- next col -->
  <div class='text'>
<div class="interleave" style="font-size: 70%">
<table>
<thead>
<tr>
<th>X→Y</th>
<th>Y→X</th>
</tr>
</thead>
<tbody>
<tr>
<td>x.TransferTo(y)</td>
<td>y.TransferTo(x)</td>
</tr>
<tr>
<td><strong>x</strong>.mu.Lock()</td>
<td><strong>y</strong>.mu.Lock()</td>
</tr>
<tr>
<td>x.changeBalanceLocked()</td>
<td>y.changeBalanceLocked()</td>
</tr>
<tr>
<td><strong>y</strong>.mu.Lock()</td>
<td><strong>x</strong>.mu.Lock()</td>
</tr>
<tr>
<td>DEADLOCK</td>
<td>DEADLOCK</td>
</tr>
</tbody>
</table>
  </div>
  <br/>
  <div class='text'>
<p>That is only one interleaving!</p>
  </div>
  <span class='pagenumber'>11</span>
</article>

<!-- slide 12 -->
<article>
  <h1>Solution 1: coarser granularity</h1>
  Locks protect larger critical sections.<br/>
  <div class="flex"><div>
  <div class='code small'><pre>
<span class='codenum'>1</span>type <defn>Accounts</defn> struct {
<span class='codenum'>2</span>   mu       sync.Mutex
<span class='codenum'>3</span>   balances map[string]int <comment>// account name to balance</comment>
<span class='codenum'>4</span>}

<span class='codenum'>5</span>func (a *Accounts) <defn>Balance</defn>(name string) int {
<span class='codenum'>6</span>   a.mu.Lock()
<span class='codenum'>7</span>   defer a.mu.Unlock()
<span class='codenum'>8</span>   return a.balances[name]
<span class='codenum'>9</span>}

<span class='codenum'>10</span>func (a *Accounts) <defn>Deposit</defn>(name string, amount int) {
<span class='codenum'>11</span>   a.mu.Lock()
<span class='codenum'>12</span>   defer a.mu.Unlock()
<span class='codenum'>13</span>   a.changeBalanceLocked(name, amount)
<span class='codenum'>14</span>}

<span class='codenum'>15</span>func (a *Accounts) <defn>Withdraw</defn>(name string, amount int) {
<span class='codenum'>16</span>   a.mu.Lock()
<span class='codenum'>17</span>   defer a.mu.Unlock()
<span class='codenum'>18</span>   a.changeBalanceLocked(name, -amount)
<span class='codenum'>19</span>}
</pre>
  </div>
  </div>
  <div> <!-- next col -->
  <div class='code small'><pre>

<span class='codenum'>1</span>func (a *Accounts) <defn>changeBalanceLocked</defn>(name string, amount int) {
<span class='codenum'>2</span>   a.balances[name] += amount
<span class='codenum'>3</span>}

<span class='codenum'>4</span>func (a *Accounts) <defn>TransferTo</defn>(fromName, toName string, amount int) {
<span class='codenum'>5</span>   a.mu.Lock()
<span class='codenum'>6</span>   defer a.mu.Unlock()
<span class='codenum'>7</span>   a.changeBalanceLocked(fromName, -amount)
<span class='codenum'>8</span>   a.changeBalanceLocked(toName, amount)
<span class='codenum'>9</span>}
</pre>
  </div>
  <div class='text'>
<p>Either Xena grabs the lock first, or Yuri does.</p>
  </div>
  <details>
    <summary>
What's the problem with this approach?    </summary>
    <div class='answer'>
<p>No concurrency: only one goroutine can work with <em>any</em> account at a time.</p>
    </div>
  </details>
  </div></div> <!-- flex -->
  <span class='pagenumber'>12</span>
</article>

<!-- slide 13 -->
<article>
  <h1>Solution 2: lock ordering</h1>
  If all goroutines obtain locks in the same order, deadlock is impossible.<br/>
  <div class="flex"><div>
  <div class='code'><pre>
<span class='codenum'>1</span>type <defn>Account</defn> struct {
<span class='codenum'>2</span>   mu      sync.Mutex
<span class='codenum'>3</span>   balance int
<span class='codenum'>4</span><span class="em">   id      int <comment>// unique for each account</span></comment>
<span class='codenum'>5</span>}
</pre>
  </div>
  </div>
  <div> <!-- next col -->
  <div class='code'><pre>

<span class='codenum'>1</span>func (a *Account) <defn>TransferTo</defn>(b *Account, amount int) {
<span class='codenum'>2</span>   <comment>// Acquire locks in ID order.</comment>
<span class='codenum'>3</span><span class="em">   if a.id &lt; b.id {
<span class='codenum'>4</span>      a.mu.Lock()
<span class='codenum'>5</span>      b.mu.Lock()
<span class='codenum'>6</span>   } else {
<span class='codenum'>7</span>      b.mu.Lock()
<span class='codenum'>8</span>      a.mu.Lock()
<span class='codenum'>9</span>   }</span>
<span class='codenum'>10</span>   <comment>// Unlock order doesn&#39;t matter.</comment>
<span class='codenum'>11</span>   defer a.mu.Unlock()
<span class='codenum'>12</span>   defer b.mu.Unlock()

<span class='codenum'>13</span>   a.changeBalanceLocked(-amount)
<span class='codenum'>14</span>   b.changeBalanceLocked(amount)
<span class='codenum'>15</span>}
</pre>
  </div>
  <span class='pagenumber'>13</span>
</article>

<!-- slides/mutexes-advanced/30-checklocks.go -->

<!-- slide 14 -->
<article class='title-slide'>
  <div class='title-text'>checklocks</div>
  <span class='pagenumber'>14</span>
</article>

<!-- slide 15 -->
<article>
  <h1>Overview</h1>
  <div class='text'>
<p>Checklocks is a tool developed by Google's gvisor team.</p>
<p>Installation:</p>
<pre><code>go install gvisor.dev/gvisor/tools/checklocks/cmd/checklocks@go
</code></pre>
<p>Use:</p>
<pre><code>checklocks ./...
</code></pre>
  </div>
  <span class='pagenumber'>15</span>
</article>

<!-- slide 16 -->
<article>
  <h1>Example</h1>
  <div class='code'><pre>
<span class='codenum'>1</span>type <defn>Account</defn> struct {
<span class='codenum'>2</span>   mu      sync.Mutex
<span class='codenum'>3</span>   balance int
<span class='codenum'>4</span>}

<span class='codenum'>5</span>func (a *Account) <defn>changeBalanceLocked</defn>(amount int) {
<span class='codenum'>6</span>   a.balance += amount
<span class='codenum'>7</span>}

<span class='codenum'>8</span>func (a *Account) <defn>TransferTo</defn>(b *Account, amount int) {
<span class='codenum'>9</span>   a.mu.Lock()
<span class='codenum'>10</span>   defer a.mu.Unlock()
<span class='codenum'>11</span>   a.changeBalanceLocked(-amount)
<span class='codenum'>12</span>   b.changeBalanceLocked(amount)
<span class='codenum'>13</span>}
</pre>
  </div>
  <span class='pagenumber'>16</span>
</article>

<!-- slide 17 -->
<article>
  <h1>Example</h1>
  <div class='code'><pre>
<span class='codenum'>1</span>type <defn>Account</defn> struct {
<span class='codenum'>2</span>   mu sync.Mutex
<span class='codenum'>3</span>   <comment>// +checklocks:mu</comment>
<span class='codenum'>4</span>   balance int
<span class='codenum'>5</span>}

<span class='codenum'>6</span>func (a *Account) <defn>changeBalanceLocked</defn>(amount int) {
<span class='codenum'>7</span>   a.balance += amount
<span class='codenum'>8</span>}

<span class='codenum'>9</span>func (a *Account) <defn>TransferTo</defn>(b *Account, amount int) {
<span class='codenum'>10</span>   a.mu.Lock()
<span class='codenum'>11</span>   defer a.mu.Unlock()
<span class='codenum'>12</span>   a.changeBalanceLocked(-amount)
<span class='codenum'>13</span>   b.changeBalanceLocked(amount)
<span class='codenum'>14</span>}
</pre>
  </div>
<div></div>
  <div class='output'><pre>
file.go:7:4: invalid field access, mu (&({param:a}.mu)) must be locked when accessing balance
</pre>
  </div>
  <span class='pagenumber'>17</span>
</article>

<!-- slide 18 -->
<article>
  <h1>Example, v2</h1>
  <div class='code'><pre>
<span class='codenum'>1</span>type <defn>Account</defn> struct {
<span class='codenum'>2</span>   mu      sync.Mutex
<span class='codenum'>3</span>   balance int
<span class='codenum'>4</span>}

<comment>// +checklocks:a.mu</comment>
<span class='codenum'>5</span>func (a *Account) <defn>changeBalanceLocked</defn>(amount int) {
<span class='codenum'>6</span>   a.balance += amount
<span class='codenum'>7</span>}

<span class='codenum'>8</span>func (a *Account) <defn>TransferTo</defn>(b *Account, amount int) {
<span class='codenum'>9</span>   a.mu.Lock()
<span class='codenum'>10</span>   defer a.mu.Unlock()
<span class='codenum'>11</span>   a.changeBalanceLocked(-amount)
<span class='codenum'>12</span>   b.changeBalanceLocked(amount)
<span class='codenum'>13</span>}
</pre>
  </div>
